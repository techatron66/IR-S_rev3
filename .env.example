# Environment Configuration
# Copy this file to .env and update values for your environment

# For local development (PC + Phone on same WiFi)
PROF_SERVER=http://192.168.1.100:8000
STUDENT_URL=http://192.168.1.100:8002

# For localhost only (PC only, no phone access)
# PROF_SERVER=http://localhost:8000
# STUDENT_URL=http://localhost:8002

# For Codespaces (if needed)
# PROF_SERVER=https://your-codespace-name-8000.preview.app.github.dev
# STUDENT_URL=https://your-codespace-name-8002.preview.app.github.dev

# For production/deployed servers
# PROF_SERVER=https://your-domain.com/prof
# STUDENT_URL=https://your-domain.com/student
